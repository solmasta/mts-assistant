<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="theme-color" content="#E30613"/>
<title>MTS Assistant – JLL</title>
<meta name="description" content="JLL MTS AI Field Assistant for HVAC engineers"/>
<link rel="manifest" href="manifest.json">
<link rel="icon" href="favicon.ico">
<link rel="apple-touch-icon" href="icon-192.png">
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="MTS Assistant"/>
<meta name="mobile-web-app-capable" content="yes"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;height:100dvh;font-family:system-ui,-apple-system,sans-serif;overflow:hidden;width:100%;transition:background 0.4s ease}
#root{height:100%;height:100dvh;display:flex;flex-direction:column;overflow:hidden;width:100%;position:relative}

#root::before {
  content:"";
  position:fixed;
  inset:0;
  pointer-events:none;
  z-index:0;
  background-image:
    radial-gradient(ellipse 90% 45% at 50% 0%, rgba(227,6,19,0.22) 0%, transparent 65%),
    radial-gradient(ellipse 50% 35% at 100% 100%, rgba(227,6,19,0.1) 0%, transparent 60%),
    radial-gradient(ellipse 40% 25% at 0% 60%, rgba(180,0,10,0.07) 0%, transparent 55%),
    linear-gradient(rgba(227,6,19,0.07) 1px, transparent 1px),
    linear-gradient(90deg, rgba(227,6,19,0.07) 1px, transparent 1px);
  background-size:100% 100%,100% 100%,100% 100%,32px 32px,32px 32px;
  transition:opacity 0.5s ease;
}
body.light-mode #root::before { opacity:0.35; }

#root::after {
  content:"";
  position:fixed;
  inset:0;
  pointer-events:none;
  z-index:0;
  background-image:
    repeating-linear-gradient(-45deg,transparent,transparent 60px,rgba(227,6,19,0.025) 60px,rgba(227,6,19,0.025) 61px);
  transition:opacity 0.5s ease;
}
body.light-mode #root::after { opacity:0.4; }

#root > div { position:relative; z-index:1; }

#theme-ripple {
  position:fixed;
  border-radius:50%;
  pointer-events:none;
  z-index:99999;
  transform:scale(0);
  opacity:0;
  transition:none;
}
#theme-ripple.expanding {
  transition:transform 0.55s cubic-bezier(0.4,0,0.2,1), opacity 0.15s ease 0.4s;
  transform:scale(1);
  opacity:0;
}

body.light-mode { color:#111; }

::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(227,6,19,0.4);border-radius:3px}

@keyframes slideUp {
  from { opacity:0; transform:translateY(18px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes slideIn {
  from { opacity:0; transform:translateX(22px); }
  to   { opacity:1; transform:translateX(0); }
}
@keyframes fadeIn {
  from { opacity:0; }
  to   { opacity:1; }
}
@keyframes popIn {
  0%   { opacity:0; transform:scale(0.88); }
  60%  { opacity:1; transform:scale(1.03); }
  100% { transform:scale(1); }
}
@keyframes shimmer {
  0%   { background-position:200% center; }
  100% { background-position:-200% center; }
}

.anim-slideUp  { animation:slideUp  0.28s cubic-bezier(0.16,1,0.3,1) both; }
.anim-slideIn  { animation:slideIn  0.26s cubic-bezier(0.16,1,0.3,1) both; }
.anim-fadeIn   { animation:fadeIn   0.22s ease both; }
.anim-popIn    { animation:popIn    0.3s  cubic-bezier(0.34,1.56,0.64,1) both; }

.anim-slideUp:nth-child(1){animation-delay:0ms}
.anim-slideUp:nth-child(2){animation-delay:40ms}
.anim-slideUp:nth-child(3){animation-delay:80ms}
.anim-slideUp:nth-child(4){animation-delay:120ms}
.anim-slideUp:nth-child(5){animation-delay:160ms}
.anim-slideUp:nth-child(6){animation-delay:200ms}

button { transition:transform 0.08s ease, box-shadow 0.15s ease, background 0.15s ease, opacity 0.15s ease; }
button:active { transform:scale(0.96) !important; }

@keyframes ctaPulse {
  0%,100% { box-shadow:0 8px 28px rgba(227,6,19,0.45), inset 0 1px 0 rgba(255,255,255,.15); }
  50%      { box-shadow:0 8px 40px rgba(227,6,19,0.7),  inset 0 1px 0 rgba(255,255,255,.15); }
}
.cta-pulse { animation:ctaPulse 2.4s ease-in-out infinite; }

@keyframes tabSlide {
  from { transform:scaleX(0); }
  to   { transform:scaleX(1); }
}
.tab-active-bar { animation:tabSlide 0.2s cubic-bezier(0.34,1.56,0.64,1) both; transform-origin:center; }

@keyframes toggleSpin {
  from { transform:rotate(-180deg) scale(0.5); opacity:0; }
  to   { transform:rotate(0deg)    scale(1);   opacity:1; }
}
.theme-icon-spin { animation:toggleSpin 0.35s cubic-bezier(0.34,1.56,0.64,1) both; }

@keyframes resultReveal {
  from { opacity:0; transform:translateY(12px) scale(0.98); }
  to   { opacity:1; transform:translateY(0)    scale(1); }
}
.anim-result { animation:resultReveal 0.35s cubic-bezier(0.16,1,0.3,1) both; }

@keyframes bounce{0%,80%,100%{transform:translateY(0);opacity:.4}40%{transform:translateY(-8px);opacity:1}}
.bounce-dot{animation:bounce 1.2s infinite}

#splash{position:fixed;inset:0;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .5s}
#splash img{width:220px;border-radius:8px;margin-bottom:20px}
.bar{width:180px;height:3px;background:#222;border-radius:2px;overflow:hidden}
.bar-fill{height:100%;background:#E30613;animation:load 2.5s ease forwards}
@keyframes load{from{width:0}to{width:100%}}

input,select,textarea{font-family:inherit;transition:border-color 0.2s ease,box-shadow 0.2s ease}
input:focus,select:focus,textarea:focus{outline:none;border-color:rgba(227,6,19,0.6)!important;box-shadow:0 0 0 3px rgba(227,6,19,0.12)!important}
</style>
</head>
<body>
<noscript>You need to enable JavaScript to run this app.</noscript>
<div id="root"></div>
<script defer="defer" src="/mts-assistant/static/js/main.f0cf66bb.js"></script>
</body>
</html>
